# ZBlog Backend Environment Variables
# 复制为 .env 并填入实际值，或通过 docker run -e 传入
# 所有 ZBLOG_* 变量都会自动覆盖 config.yaml 中的对应字段

# 数据库（必填）
ZBLOG_DATABASE_HOST=127.0.0.1
ZBLOG_DATABASE_PORT=3306
ZBLOG_DATABASE_USER=root
ZBLOG_DATABASE_PASSWORD=your_db_password
ZBLOG_DATABASE_DBNAME=zblog

# JWT（必填，生产环境务必修改）
ZBLOG_JWT_SECRET=请生成一个随机字符串

# 服务运行模式（debug / release）
ZBLOG_SERVER_MODE=release
ZBLOG_SERVER_PORT=8080

# 日志级别（debug / info / warn / error）
ZBLOG_LOG_LEVEL=info

# 所有环境变量名称规则：
# config.yaml 中的 database.password → ZBLOG_DATABASE_PASSWORD
# config.yaml 中的 server.mode     → ZBLOG_SERVER_MODE
# 规则: 全大写 + 点号替换为下划线 + ZBLOG_ 前缀
